<Router AppAssembly="typeof(RynthRemote.MauiProgram).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(RynthRemote.Components.Layout.MainLayout)" />
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
    <NotFound>
        <LayoutView Layout="typeof(RynthRemote.Components.Layout.MainLayout)">
            <div class="card-r"><p class="muted">Page not found.</p></div>
        </LayoutView>
    </NotFound>
</Router>
