<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>UIDeviceFamily</key>
    <array>
        <integer>1</integer>
        <integer>2</integer>
    </array>
    <key>UIRequiredDeviceCapabilities</key>
    <array>
        <string>arm64</string>
    </array>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <key>XSAppIconAssets</key>
    <string>Assets.xcassets/appicon.appiconset</string>

    <!-- RynthRemote talks to the RynthCore StatusAgent over plain HTTP on a private address
         (your Tailscale/LAN PC). iOS blocks cleartext by default; this sideloaded companion
         app allows it so the phone can reach the agent. -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <true/>
    </dict>

    <!-- HD video mode uses WebRTC. iOS gates the peer-to-peer ICE connectivity (LAN/Tailscale
         candidate gathering + mDNS) behind the Local Network permission; without this declaration
         WKWebView's ICE fails even though plain HTTP works. NSBonjourServices declares the WebRTC
         mDNS service so the .local candidates iOS emits can be resolved. -->
    <key>NSLocalNetworkUsageDescription</key>
    <string>RynthRemote streams your AC client to this device over your local network / Tailscale.</string>
    <key>NSBonjourServices</key>
    <array>
        <string>_webrtc._udp</string>
    </array>
</dict>
</plist>
